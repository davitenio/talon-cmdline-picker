list: user.unix_utility_immediate
-

# These commands are executed immediately. That is, they are pasted
# into the command line and then Talon automatically presses Enter.
brew update
brew upgrade
dig
disk free human: df -h
disk free: df
harp top: htop
I D user: id -u
I D: id
lisa now: ls
lisa dot dot | lisa double dot: ls ..
lisa li now: ls -l
lisa triple dot: ls ../..
open dot: open .
who
who am I: whoami
work dear: pwd